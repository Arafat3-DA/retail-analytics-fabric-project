{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/reportExtension/1.0.0/schema.json",
  "name": "extension",
  "entities": [
    {
      "name": "Measures_",
      "measures": [
        {
          "name": "Total Sales",
          "dataType": "Double",
          "expression": "SUM(fact_sales[SalesAmountUSD])",
          "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00"
        },
        {
          "name": "Gross Profit",
          "dataType": "Double",
          "expression": "SUM(fact_sales[GrossProfitUSD])",
          "formatString": "0.00"
        },
        {
          "name": "Total Quantity Sold",
          "dataType": "Double",
          "expression": "SUM(fact_sales[Quantity])",
          "formatString": "0.00"
        },
        {
          "name": "Total Orders",
          "dataType": "Double",
          "expression": "DISTINCTCOUNT(fact_sales[OrderKey])",
          "formatString": "0.00"
        },
        {
          "name": "Total Customers",
          "dataType": "Double",
          "expression": "DISTINCTCOUNT(fact_sales[CustomerKey])",
          "formatString": "0.00"
        },
        {
          "name": "Total Stores",
          "dataType": "Double",
          "expression": "DISTINCTCOUNT(fact_sales[StoreKey])",
          "formatString": "0"
        },
        {
          "name": "Total Products Sold",
          "dataType": "Double",
          "expression": "DISTINCTCOUNT(fact_sales[ProductKey])",
          "formatString": "0.00"
        },
        {
          "name": "Gross Profit Margin",
          "dataType": "Double",
          "expression": "DIVIDE([Gross Profit], [Total Sales])",
          "formatString": "0.00\\ %;-0.00\\ %;0.00\\ %",
          "references": {
            "measures": [
              {
                "schema": "extension",
                "entity": "Measures_",
                "name": "Gross Profit"
              },
              {
                "schema": "extension",
                "entity": "Measures_",
                "name": "Total Sales"
              }
            ]
          }
        },
        {
          "name": "Average Order Value",
          "dataType": "Double",
          "expression": "DIVIDE([Total Sales], [Total Orders])",
          "formatString": "0.00",
          "references": {
            "measures": [
              {
                "schema": "extension",
                "entity": "Measures_",
                "name": "Total Sales"
              },
              {
                "schema": "extension",
                "entity": "Measures_",
                "name": "Total Orders"
              }
            ]
          }
        },
        {
          "name": "Average Quantity per Order",
          "dataType": "Double",
          "expression": "DIVIDE([Total Quantity Sold],[Total Orders])",
          "formatString": "0.00",
          "references": {
            "measures": [
              {
                "schema": "extension",
                "entity": "Measures_",
                "name": "Total Quantity Sold"
              },
              {
                "schema": "extension",
                "entity": "Measures_",
                "name": "Total Orders"
              }
            ]
          }
        },
        {
          "name": "Revenue per Customer",
          "dataType": "Double",
          "expression": "DIVIDE([Total Sales], [Total Customers])",
          "formatString": "0.00",
          "references": {
            "measures": [
              {
                "schema": "extension",
                "entity": "Measures_",
                "name": "Total Sales"
              },
              {
                "schema": "extension",
                "entity": "Measures_",
                "name": "Total Customers"
              }
            ]
          }
        },
        {
          "name": "Revenue per Store",
          "dataType": "Double",
          "expression": "DIVIDE([Total Sales], [Total Stores])",
          "formatString": "0.00",
          "references": {
            "measures": [
              {
                "schema": "extension",
                "entity": "Measures_",
                "name": "Total Sales"
              },
              {
                "schema": "extension",
                "entity": "Measures_",
                "name": "Total Stores"
              }
            ]
          }
        },
        {
          "name": "Gross Profit per Customer",
          "dataType": "Double",
          "expression": "DIVIDE([Gross Profit], [Total Customers])",
          "formatString": "0.00",
          "references": {
            "measures": [
              {
                "schema": "extension",
                "entity": "Measures_",
                "name": "Gross Profit"
              },
              {
                "schema": "extension",
                "entity": "Measures_",
                "name": "Total Customers"
              }
            ]
          }
        },
        {
          "name": "Cost of Sales",
          "dataType": "Double",
          "expression": "SUMX(fact_sales, fact_sales[Quantity] * fact_sales[UnitCost] / fact_sales[ExchangeRate])",
          "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00"
        },
        {
          "name": "Sales MTD",
          "dataType": "Double",
          "expression": "TOTALMTD([Total Sales],dim_date[Date])",
          "formatString": "0.00",
          "references": {
            "measures": [
              {
                "schema": "extension",
                "entity": "Measures_",
                "name": "Total Sales"
              }
            ]
          }
        },
        {
          "name": "Sales QTD",
          "dataType": "Double",
          "expression": "TOTALQTD([Total Sales], dim_date[Date])",
          "formatString": "0.00",
          "references": {
            "measures": [
              {
                "schema": "extension",
                "entity": "Measures_",
                "name": "Total Sales"
              }
            ]
          }
        },
        {
          "name": "Sales YTD",
          "dataType": "Double",
          "expression": "TOTALYTD([Total Sales], dim_date[Date])",
          "formatString": "0.00",
          "references": {
            "measures": [
              {
                "schema": "extension",
                "entity": "Measures_",
                "name": "Total Sales"
              }
            ]
          }
        },
        {
          "name": "Gross Profit MTD",
          "dataType": "Double",
          "expression": "TOTALMTD([Gross Profit], dim_date[Date])",
          "formatString": "0.00",
          "references": {
            "measures": [
              {
                "schema": "extension",
                "entity": "Measures_",
                "name": "Gross Profit"
              }
            ]
          }
        },
        {
          "name": "Gross Profit YTD",
          "dataType": "Double",
          "expression": "TOTALYTD([Gross Profit], dim_date[Date])",
          "formatString": "0.00",
          "references": {
            "measures": [
              {
                "schema": "extension",
                "entity": "Measures_",
                "name": "Gross Profit"
              }
            ]
          }
        },
        {
          "name": "Total Sales LY",
          "dataType": "Double",
          "expression": "CALCULATE([Total Sales], \n                   SAMEPERIODLASTYEAR(dim_date[Date]))",
          "formatString": "0.00",
          "references": {
            "measures": [
              {
                "schema": "extension",
                "entity": "Measures_",
                "name": "Total Sales"
              }
            ]
          }
        },
        {
          "name": "Total Gross Profit LY",
          "dataType": "Double",
          "expression": "CALCULATE([Gross Profit],\n                        SAMEPERIODLASTYEAR(dim_date[Date]))",
          "formatString": "0.00",
          "references": {
            "measures": [
              {
                "schema": "extension",
                "entity": "Measures_",
                "name": "Gross Profit"
              }
            ]
          }
        },
        {
          "name": "Total Orders LY",
          "dataType": "Double",
          "expression": "CALCULATE([Total Orders],\n                  SAMEPERIODLASTYEAR(dim_date[Date]))",
          "formatString": "0.00",
          "references": {
            "measures": [
              {
                "schema": "extension",
                "entity": "Measures_",
                "name": "Total Orders"
              }
            ]
          }
        },
        {
          "name": "Total Quantity Sold LY",
          "dataType": "Double",
          "expression": "CALCULATE([Total Quantity Sold],\r\n                         SAMEPERIODLASTYEAR(dim_date[Date]))",
          "formatString": "0.00",
          "references": {
            "measures": [
              {
                "schema": "extension",
                "entity": "Measures_",
                "name": "Total Quantity Sold"
              }
            ]
          }
        },
        {
          "name": "Sales LYTD",
          "dataType": "Double",
          "expression": "CALCULATE([Sales YTD],\r\n             SAMEPERIODLASTYEAR(dim_date[Date]))",
          "references": {
            "measures": [
              {
                "schema": "extension",
                "entity": "Measures_",
                "name": "Sales YTD"
              }
            ]
          }
        },
        {
          "name": "Sales LMTD",
          "dataType": "Double",
          "expression": "CALCULATE([Sales MTD],\r\n             DATEADD(dim_date[Date],-1,MONTH))",
          "formatString": "0.00",
          "references": {
            "measures": [
              {
                "schema": "extension",
                "entity": "Measures_",
                "name": "Sales MTD"
              }
            ]
          }
        },
        {
          "name": "Sales YoY %",
          "dataType": "Double",
          "expression": "\nDIVIDE([Total Sales] - [Total Sales LY], [Total Sales LY])",
          "formatString": "0.00\\ %;-0.00\\ %;0.00\\ %",
          "references": {
            "measures": [
              {
                "schema": "extension",
                "entity": "Measures_",
                "name": "Total Sales"
              },
              {
                "schema": "extension",
                "entity": "Measures_",
                "name": "Total Sales LY"
              }
            ]
          }
        },
        {
          "name": "Gross Profit YoY %",
          "dataType": "Double",
          "expression": "\nDIVIDE([Gross Profit] - [Total Gross Profit LY], [Total Gross Profit LY])",
          "formatString": "0.00\\ %;-0.00\\ %;0.00\\ %",
          "references": {
            "measures": [
              {
                "schema": "extension",
                "entity": "Measures_",
                "name": "Gross Profit"
              },
              {
                "schema": "extension",
                "entity": "Measures_",
                "name": "Total Gross Profit LY"
              }
            ]
          }
        },
        {
          "name": "Orders YoY %",
          "dataType": "Double",
          "expression": "\nDIVIDE([Total Orders] - [Total Orders LY], [Total Orders LY])",
          "formatString": "0.00\\ %;-0.00\\ %;0.00\\ %",
          "references": {
            "measures": [
              {
                "schema": "extension",
                "entity": "Measures_",
                "name": "Total Orders"
              },
              {
                "schema": "extension",
                "entity": "Measures_",
                "name": "Total Orders LY"
              }
            ]
          }
        },
        {
          "name": "Quantity YoY %",
          "dataType": "Double",
          "expression": "\nDIVIDE([Total Quantity Sold] - [Total Quantity Sold LY], [Total Quantity Sold LY])",
          "formatString": "0.00\\ %;-0.00\\ %;0.00\\ %",
          "references": {
            "measures": [
              {
                "schema": "extension",
                "entity": "Measures_",
                "name": "Total Quantity Sold"
              },
              {
                "schema": "extension",
                "entity": "Measures_",
                "name": "Total Quantity Sold LY"
              }
            ]
          }
        },
        {
          "name": "Sales YTD vs LY %",
          "dataType": "Double",
          "expression": "\nDIVIDE([Sales YTD] - [Sales LYTD], [Sales LYTD])",
          "formatString": "0.00\\ %;-0.00\\ %;0.00\\ %",
          "references": {
            "measures": [
              {
                "schema": "extension",
                "entity": "Measures_",
                "name": "Sales YTD"
              },
              {
                "schema": "extension",
                "entity": "Measures_",
                "name": "Sales LYTD"
              }
            ]
          }
        },
        {
          "name": "Sales Variance LY",
          "dataType": "Double",
          "expression": "\n[Total Sales] - [Total Sales LY]",
          "formatString": "0.00",
          "references": {
            "measures": [
              {
                "schema": "extension",
                "entity": "Measures_",
                "name": "Total Sales"
              },
              {
                "schema": "extension",
                "entity": "Measures_",
                "name": "Total Sales LY"
              }
            ]
          }
        },
        {
          "name": "Product Sales Rank",
          "dataType": "Double",
          "expression": "\nRANKX(\n    ALL(dim_product[ProductName]),\n    [Total Sales],\n    ,\n    DESC,\n    DENSE\n)",
          "references": {
            "measures": [
              {
                "schema": "extension",
                "entity": "Measures_",
                "name": "Total Sales"
              }
            ]
          }
        },
        {
          "name": "Store Sales Rank",
          "dataType": "Double",
          "expression": "\nRANKX(ALL(dim_store[Description]), [Total Sales],,DESC,Dense)",
          "references": {
            "measures": [
              {
                "schema": "extension",
                "entity": "Measures_",
                "name": "Total Sales"
              }
            ]
          }
        },
        {
          "name": "Avg Customer Age",
          "dataType": "Double",
          "expression": "\nAVERAGE(dim_customer[Age])",
          "formatString": "0.00"
        },
        {
          "name": "Orders per Customer",
          "dataType": "Double",
          "expression": "\nDIVIDE([Total Orders], [Total Customers])",
          "formatString": "0.00",
          "references": {
            "measures": [
              {
                "schema": "extension",
                "entity": "Measures_",
                "name": "Total Orders"
              },
              {
                "schema": "extension",
                "entity": "Measures_",
                "name": "Total Customers"
              }
            ]
          }
        }
      ]
    }
  ]
}